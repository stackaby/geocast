 {
  "compilerOptions": {
    "outDir": "./dist",
    "composite": true,
    "lib": ["esnext", "dom", "dom.iterable"],
    "target": "esnext",
    "moduleResolution": "nodenext",
    "module": "nodenext",
    "strict": true,
    "skipLibCheck": true,
    "verbatimModuleSyntax": true,
    "esModuleInterop": true,
    "moduleDetection": "force",
    "noUncheckedIndexedAccess": true
  },
  "include": [
      //"./frontend/**/*",
      "./backend/**/*"
   ]
}
